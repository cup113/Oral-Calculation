{
  "name": "oral-calculation",
  "version": "0.6.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "ts-check": "vue-tsc --noEmit",
    "check": "pnpm run ts-check && pnpm run coverage",
    "build": "vite build",
    "build:docs": "markdown-to-html-cli --source README.md -o \"public/README.html\" && markdown-to-html-cli --source CHANGELOG.md -o \"public/CHANGELOG.html\"",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "big-integer": "^1.6.52",
    "js-file-downloader": "^1.1.25",
    "pinia": "^3.0.3",
    "qrcode-generator": "^1.4.4",
    "vue": "^3.5.18",
    "vue-m-message": "^4.0.2",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^24.2.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^21.1.2",
    "markdown-to-html-cli": "^5",
    "tailwindcss": "^4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3",
    "vue-tsc": "^2.2.12",
    "workbox-window": "^7.4.0"
  }
